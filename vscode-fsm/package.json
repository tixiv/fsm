{
    "name": "fsm-language",
    "displayName": "FSM Language",
    "description": "Syntax highlighting for the FSM programming language",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "fsm",
                "aliases": [
                    "FSM"
                ],
                "extensions": [
                    ".fsm"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "fsm",
                "scopeName": "source.fsm",
                "path": "./syntaxes/fsm.tmLanguage.json"
            }
        ]
    }
}