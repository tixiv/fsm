{
    "scopeName": "source.fsm",
    "name": "FSM",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.fsm",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.fsm",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.interpolated.fsm",
                    "begin": "\\$\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "include": "#string-escape"
                        },
                        {
                            "include": "#interpolation"
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.fsm",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "include": "#string-escape"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.fsm",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "include": "#string-escape"
                        }
                    ]
                }
            ]
        },
        "string-escape": {
            "patterns": [
                {
                    "name": "constant.character.escape.fsm",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.fsm",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.fsm",
                    "match": "\\b(fn|struct|enum|if|else|while|for|return|let|import|from|true|false)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.fsm",
                    "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|bool|void|any)\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.fsm",
                    "match": "\\b([A-Za-z_\\p{L}][A-Za-z0-9_\\p{L}]*)\\s*(?=\\()"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.fsm",
                    "match": "=>|==|!=|<=|>=|&&|\\|\\||&!=|\\|==|::|[+\\-*/%=<>!]"
                }
            ]
        },
        "interpolation": {
            "name": "meta.embedded.fsm",
            "begin": "\\{",
            "end": "\\}",
            "contentName": "source.fsm",
            "patterns": [
                {
                    "include": "$self"
                }
            ]
        }
    }
}