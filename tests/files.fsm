
fn read_file (filename: u8[])
{
    let O_RDONLY = 0
    let fd = open (filename.data, O_RDONLY)

    if (fd >= 0) {
        puts("File has been opened\n")

        let size = fsize(fd)
        
        let s: u8[];
        s.data => mmap(size, fd)
        s.len = size;

        puts("Read bytes : ") print(s.len)

        puts(s)
    }

}

fn main () {
    read_file("tests/files.fsm")

    puts("Done\n")
}
