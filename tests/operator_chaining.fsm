
fn main() {
    let i = 0;
    while(i < 10) {
        if (1 < 4 < i <= 6 < 8) print(i);
        i = i + 1;
    }
    puts ("-------\n")
    for (i = 0; i < 10; i++) {
        if (i == 2 |== 3 |== 4 |== 9) print(i);
    }
    puts ("-------\n")
    for (i = 0; i < 10; i++) {
        if (i != 2 &!= 3 &!= 4 &!= 9) print(i);
    }
}
