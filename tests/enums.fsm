
enum Animal {
    Goat = -1,
    Cow,
    Dog,
    Cat,
    Max
}

fn sound(a: Animal) {
    if (a == Animal::Goat) return "Mäh";
    if (Animal::Cow == a) return "Mooo";
    if (a == Animal::Dog) return "Wuff";
    if (a == Animal::Cat) return "Miau";
    return "";
}

fn main () {
    for (let i: i64 = Animal::Goat; i < Animal::Max; i++) {
        let a: Animal = i;
        puts("The ") puts(a.name) puts(" goes ") puts(sound(i)) puts ("\n")
    }
}
