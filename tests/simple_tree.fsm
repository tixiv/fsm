
import * from "std";

enum NodeKind {
    Add,
    Sub,
    Mul,
    Div,
    Number,
}

struct TreeNode {
    kind: NodeKind;
    value: i64;
    left: TreeNode&;
    right: TreeNode&;
}

fn init_number (n: TreeNode&, v) {
    n.kind = NodeKind::Number;
    n.value = v;
}

fn init_operator (n: TreeNode&, kind: NodeKind, left: TreeNode&, right: TreeNode&) {
    n.kind = kind
    n.left => left;
    n.right => right;
}

fn visit_children (n: TreeNode&, visit: fn (TreeNode&) : void ) {
    if (n.kind == NodeKind::Add |== NodeKind::Sub |== NodeKind::Mul |== NodeKind::Div) {
        visit(n.left)
        visit(n.right)
    }
    else if (n.kind == NodeKind::Number)
    {}
    else $"Visiting {n.kind.name} is not implemented yet.\n"
}

fn tree_visitor(n: TreeNode&) : void {
    if (n.kind == NodeKind::Add) {
        visit_children(n, tree_visitor)
        let a = n.left.value
        let b = n.right.value
        n.value = a + b
        $"+\n={n.value}\n"
    } else {
        print (n.value)
    }
}

fn main () {
    let a: TreeNode;
    init_number(&a, 42);    
    let b: TreeNode;
    init_number(&b, 2300);
    let c: TreeNode;
    init_number(&c, 13370000);
    let add_1: TreeNode;
    init_operator(&add_1, NodeKind::Add, &a, &b);
    let add_2: TreeNode;
    init_operator(&add_2, NodeKind::Add, &add_1, &c);

    tree_visitor(&add_2)
}
