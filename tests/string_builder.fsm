
import * from "std";


enum Animal {
    Goat = -1,
    Cow,
    Dog,
    Cat,
    Max
}

fn sound(a: Animal) {
    if (a == Animal::Goat) return "Mäh";
    if (Animal::Cow == a) return "Mooo";
    if (a == Animal::Dog) return "Wuff";
    if (a == Animal::Cat) return "Miau";
    return "";
}

fn main () {
    for (let i = -5; i < 101; i++) {
        puts($"a is {i} now.\n")
    }

    puts($"{-0x8000000000000000}\n")
    puts($"{-0x7fffffffffffffff}\n")
    puts($"{ 0x7fffffffffffffff}\n")

    for (let i: i64 = Animal::Goat; i < Animal::Max; i++) {
        let a: Animal = i;
        puts($"The {a.name} goes {sound(i)}\n")
    }
}
