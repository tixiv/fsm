
fn read_file (filename: u8[]) : u8[]
{
    let O_RDONLY = 0
    let fd = open (filename.data, O_RDONLY)

    let s: u8[];
    s.len = 0;

    if (fd >= 0) {
        puts("File '") puts(filename)  puts("' has been opened. ")

        let size = fsize(fd)
        
        s.data => mmap(size, fd)
        s.len = size;

        puts("Read bytes: ") print(s.len)
        return s;
    }

    return s;
}
